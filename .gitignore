-- Эффект тряски при неверном ключе
local function shakeFrame()
    local original = mainFrame.Position
    for i = 1, 8 do
        local xOffset = (i % 2 == 0) and 18 or -18
        TweenService:Create(mainFrame, TweenInfo.new(0.05, Enum.EasingStyle.Sine), {
            Position = UDim2.new(original.X.Scale, original.X.Offset + xOffset, original.Y.Scale, original.Y.Offset)
        }):Play()
        task.wait(0.05)
    end
    mainFrame.Position = original
end

-- ОСНОВНОЙ СКРИПТ (запускается после успешной верификации)
local function loadMainScript()
    -- Полная очистка старого Rayfield
    if Rayfield then
        pcall(function() Rayfield:Destroy() end)
    end
    pcall(function() game:GetService("CoreGui"):FindFirstChild("Rayfield"):Destroy() end)

    -- Загрузка Rayfield
    local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

    -- Окно
    local Window = Rayfield:CreateWindow({
        Name = "SWILL ULTIMATE",
        LoadingTitle = "SWILL Ultimate",
        LoadingSubtitle = "by Swill Way",
        ConfigurationSaving = {Enabled = true, FolderName = "SWILL_Ultimate", FileName = "Config"}
    })

    -- Вкладки
    local AimbotTab = Window:CreateTab("Aimbot", 4483362458)
    local ESPTab = Window:CreateTab("ESP", 4483362458)
    local TriggerTab = Window:CreateTab("Auto Trigger", 4483362458)
    local HitboxTab = Window:CreateTab("Hitbox", 4483362458)
    local VisualTab = Window:CreateTab("Visuals", 4483362458)

    -- НАСТРОЙКИ
    local Settings = {
        Aimbot = {
            Enabled = true,
            TeamCheck = true,
            VisibleCheck = true,
            AimPart = "Head",
            AimSpeed = 10,
            Smoothness = 0.3
        },
        ESP = {
            Enabled = true,
            Box = true,
            Tracer = true,
            Skeleton = true,
            HealthBar = true,
            Distance = true,
            EnemyColor = Color3.fromRGB(255, 0, 0),
            TeamColor = Color3.fromRGB(0, 255, 0),
            SkeletonColor = Color3.fromRGB(255, 165, 0)
        },
        Trigger = {
            Enabled = true,
            Delay = 0.05,
            TeamCheck = true,
            Key = "MouseButton2"
        },
        FOV = {
            Radius = 200,
            Show = true,
            Color = Color3.fromRGB(255, 0, 0)
        },
        Hitbox = {
            Enabled = false,
            Size = 8,
            Transparency = 0.5,
            Part = "Head"
        }
    }

    -- ПЕРЕМЕННЫЕ
    local ESPObjects = {}
    local OriginalHitboxSizes = {}
    local lastTriggerTarget = nil

    -- FOV КРУГ
    local FOVCircle = Drawing.new("Circle")
    FOVCircle.Thickness = 2
    FOVCircle.NumSides = 60
    FOVCircle.Filled = false
    FOVCircle.Transparency = 0.5
    FOVCircle.Visible = true

    -- ПРОВЕРКА ТИММЕЙТА
    local function IsTeammate(Player)
        if Player == LocalPlayer then return true end
        if Settings.Aimbot.TeamCheck or Settings.Trigger.TeamCheck then
            return Player.Team == LocalPlayer.Team
        end
        return false
    end

    -- ПРОВЕРКА ВИДИМОСТИ
    local function IsVisible(targetPart)
        local origin = Camera.CFrame.Position
        local rayParams = RaycastParams.new()
        rayParams.FilterDescendantsInstances = {LocalPlayer.Character}
        rayParams.FilterType = Enum.RaycastFilterType.Blacklist
        
        local direction = (targetPart.Position - origin).Unit * (targetPart.Position - origin).Magnitude
        local rayResult = workspace:Raycast(origin, direction, rayParams)
        
        return not rayResult or rayResult.Instance:IsDescendantOf(targetPart.Parent)
    end

    -- ПОЛУЧЕНИЕ БЛИЖАЙШЕГО ВРАГА
    local function GetClosestEnemy()
        local center = Camera.ViewportSize / 2
        local closest = nil
        local closestDist = Settings.FOV.Radius
        
        for _, player in pairs(Players:GetPlayers()) do
            if player == LocalPlayer then continue end
            if IsTeammate(player) then continue end
            
            local char = player.Character
            if not char then continue end
            
            local humanoid = char:FindFirstChild("Humanoid")
            if not humanoid or humanoid.Health <= 0 then continue end
            
            local aimPart = char:FindFirstChild(Settings.Aimbot.AimPart)
            if not aimPart then
                aimPart = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
            end
            if not aimPart then continue end
            
            local screenPos, onScreen = Camera:WorldToViewportPoint(aimPart.Position)
            if onScreen and screenPos.Z > 0 then
                local distToCenter = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                
                if distToCenter < closestDist then
                    local visible = true
                    if Settings.Aimbot.VisibleCheck then
                        visible = IsVisible(aimPart)
                    end
                    
                    if visible then
                        closestDist = distToCenter
                        closest = {
                            Player = player,
                            Part = aimPart,
                            ScreenPos = Vector2.new(screenPos.X, screenPos.Y)
                        }
                    end
                end
            end
        end
        
        return closest
    end

    -- AIMBOT
    local function DoAimbot(target)
        if not target or not target.ScreenPos then return end
        
        local center = Camera.ViewportSize / 2
        local delta = target.ScreenPos - center
        
        pcall(function()
            if mousemoverel then
                if Settings.Aimbot.AimSpeed >= 10 then
                    mousemoverel(delta.X, delta.Y)
                else
                    local smooth = Settings.Aimbot.Smoothness or 0.3
                    mousemoverel(delta.X * smooth, delta.Y * smooth)
                end
            end
        end)
    end

    -- === ESP ФУНКЦИИ ===
    local function CreateESP(Player)
        if ESPObjects[Player] then return end
        
        local objs = {
            Box = Drawing.new("Square"),
            Tracer = Drawing.new("Line"),
            Skeleton = {},
            HealthBarBg = Drawing.new("Square"),
            HealthBarFg = Drawing.new("Square"),
            DistanceText = Drawing.new("Text")
        }
        
        for i = 1, 8 do
            objs.Skeleton[i] = Drawing.new("Line")
            objs.Skeleton[i].Thickness = 2
        end
        
        objs.Box.Thickness = 2
        objs.Box.Filled = false
        objs.Tracer.Thickness = 2
        objs.HealthBarBg.Thickness = 0
        objs.HealthBarBg.Filled = true
        objs.HealthBarBg.Transparency = 0.5
        objs.HealthBarFg.Thickness = 0
        objs.HealthBarFg.Filled = true
        objs.DistanceText.Size = 14
        objs.DistanceText.Center = true
        objs.DistanceText.Outline = true
        
        ESPObjects[Player] = objs
    end

    local function UpdateESP()
        if not Settings.ESP.Enabled then
            for _, objs in pairs(ESPObjects) do
                objs.Box.Visible = false
                objs.Tracer.Visible = false
                for _, line in pairs(objs.Skeleton) do line.Visible = false end
                objs.HealthBarBg.Visible = false
                objs.HealthBarFg.Visible = false
                objs.DistanceText.Visible = false
            end
            return
        end
        
        for Player, objs in pairs(ESPObjects) do
            local char = Player.Character
            if not char or not char:FindFirstChild("Head") or not char:FindFirstChild("HumanoidRootPart") then
                objs.Box.Visible = false
                objs.Tracer.Visible = false
                for _, line in pairs(objs.Skeleton) do line.Visible = false end
                objs.HealthBarBg.Visible = false
                objs.HealthBarFg.Visible = false
                objs.DistanceText.Visible = false
                continue
            end
            
            local humanoid = char:FindFirstChild("Humanoid")
            if not humanoid or humanoid.Health <= 0 then
                objs.Box.Visible = false
                objs.Tracer.Visible = false
                for _, line in pairs(objs.Skeleton) do line.Visible = false end
                objs.HealthBarBg.Visible = false
                objs.HealthBarFg.Visible = false
                objs.DistanceText.Visible = false
                continue
            end
            
            local head = char.Head
            local root = char.HumanoidRootPart
            
            local headPos, onScreen = Camera:WorldToViewportPoint(head.Position)
            local rootPos = Camera:WorldToViewportPoint(root.Position)
            
            if not onScreen and rootPos.Z < 0 then
                objs.Box.Visible = false
                objs.Tracer.Visible = false
                for _, line in pairs(objs.Skeleton) do line.Visible = false end
                objs.HealthBarBg.Visible = false
                objs.HealthBarFg.Visible = false
                objs.DistanceText.Visible = false
                continue
            end
            
            local height = math.abs(rootPos.Y - headPos.Y) * 3
            local width = height / 2
            local color = IsTeammate(Player) and Settings.ESP.TeamColor or Settings.ESP.EnemyColor
            local distance = math.floor((Camera.CFrame.Position - root.Position).Magnitude)
            
            -- Box
            if Settings.ESP.Box then
                objs.Box.Size = Vector2.new(width, height)
                objs.Box.Position = Vector2.new(rootPos.X - width/2, rootPos.Y - height)
                objs.Box.Color = color
                objs.Box.Visible = true
            end
            
            -- Tracer
            if Settings.ESP.Tracer then
                objs.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                objs.Tracer.To = Vector2.new(rootPos.X, rootPos.Y)
                objs.Tracer.Color = color
                objs.Tracer.Visible = true
            end
            
            -- Skeleton (упрощенный)
            if Settings.ESP.Skeleton then
                local neckPos = Camera:WorldToViewportPoint(root.Position + Vector3.new(0, 1.5, 0))
                local lines = {
                    {headPos, neckPos},
                    {neckPos, rootPos}
                }
                for i, line in ipairs(lines) do
                    if line[1].Z > 0 and line[2].Z > 0 then
                        objs.Skeleton[i].From = Vector2.new(line[1].X, line[1].Y)
                        objs.Skeleton[i].To = Vector2.new(line[2].X, line[2].Y)
                        objs.Skeleton[i].Color = Settings.ESP.SkeletonColor
                        objs.Skeleton[i].Visible = true
                    end
                end
            end
            
            -- Health Bar
            if Settings.ESP.HealthBar then
                local healthPercent = humanoid.Health / humanoid.MaxHealth
                objs.HealthBarBg.Size = Vector2.new(4, height)
                objs.HealthBarBg.Position = Vector2.new(rootPos.X - width/2 - 6, rootPos.Y - height)
                objs.HealthBarBg.Color = Color3.fromRGB(0, 0, 0)
                objs.HealthBarBg.Visible = true
                
                objs.HealthBarFg.Size = Vector2.new(4, height * healthPercent)
                objs.HealthBarFg.Position = Vector2.new(rootPos.X - width/2 - 6, rootPos.Y - height + height * (1 - healthPercent))
                objs.HealthBarFg.Color = Color3.fromRGB(0, 255, 0):Lerp(Color3.fromRGB(255, 0, 0), 1 - healthPercent)
                objs.HealthBarFg.Visible = true
            end
            
            -- Distance
            if Settings.ESP.Distance then
                objs.DistanceText.Text = distance .. "m"
                objs.DistanceText.Position = Vector2.new(rootPos.X, rootPos.Y - height - 15)
                objs.DistanceText.Color = color
                objs.DistanceText.Visible = true
            end
        end
    end

    -- === HITBOX ===
    local function UpdateHitboxes()
        for _, Player in pairs(Players:GetPlayers()) do
            if Player == LocalPlayer then continue end
            local char = Player.Character
            if not char then continue end
            
            local part = char:FindFirstChild(Settings.Hitbox.Part)
            if not part then continue end
            
            if Settings.Hitbox.Enabled then
                if not OriginalHitboxSizes[Player] then
                    OriginalHitboxSizes[Player] = part.Size
                end
                part.Size = Vector3.new(Settings.Hitbox.Size, Settings.Hitbox.Size, Settings.Hitbox.Size)
                part.Transparency = Settings.Hitbox.Transparency
                part.CanCollide = false
            else
                if OriginalHitboxSizes[Player] then
                    part.Size = OriginalHitboxSizes[Player]
                    part.Transparency = 0
                    part.CanCollide = true
                end
            end
        end
    end

    -- === TRIGGERBOT ===
    local triggerActive = false
    
    UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton2 then
            triggerActive = true
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton2 then
            triggerActive = false
            lastTriggerTarget = nil
        end
    end)

    -- === ИНИЦИАЛИЗАЦИЯ ESP ===
    for _, Player in pairs(Players:GetPlayers()) do
        if Player ~= LocalPlayer then
            CreateESP(Player)
        end
    end
    
    Players.PlayerAdded:Connect(function(Player)
        if Player ~= LocalPlayer then
            CreateESP(Player)
        end
    end)

    -- === ГЛАВНЫЙ ЦИКЛ ===
    RunService.RenderStepped:Connect(function()
        -- FOV круг
        if Settings.FOV.Show then
            FOVCircle.Position = Camera.ViewportSize / 2
            FOVCircle.Radius = Settings.FOV.Radius
            FOVCircle.Color = Settings.FOV.Color
            FOVCircle.Visible = true
        else
            FOVCircle.Visible = false
        end
        
        -- Aimbot
        if Settings.Aimbot.Enabled then
            local target = GetClosestEnemy()
            if target then
                DoAimbot(target)
            end
        end
        
        -- Triggerbot
        if Settings.Trigger.Enabled and triggerActive then
            local target = GetClosestEnemy()
            if target then
                if target.Player ~= lastTriggerTarget then
                    pcall(function()
                        mouse1press()
                        task.wait(Settings.Trigger.Delay)
                        mouse1release()
                    end)
                    lastTriggerTarget = target.Player
                end
            else
                lastTriggerTarget = nil
            end
        end
        
        -- Update ESP и Hitboxes
        UpdateESP()
        UpdateHitboxes()
    end)

    -- === МЕНЮ RAYFIELD ===
    AimbotTab:CreateToggle({
        Name = "Aimbot Enabled",
        CurrentValue = true,
        Callback = function(v) Settings.Aimbot.Enabled = v end
    })
    
    AimbotTab:CreateToggle({
        Name = "Team Check",
        CurrentValue = true,
        Callback = function(v) Settings.Aimbot.TeamCheck = v end
    })
    
    AimbotTab:CreateToggle({
        Name = "Visible Check",
        CurrentValue = true,
        Callback = function(v) Settings.Aimbot.VisibleCheck = v end
    })
    
    AimbotTab:CreateDropdown({
        Name = "Aim Part",
        Options = {"Head", "HumanoidRootPart", "UpperTorso"},
        CurrentOption = "Head",
        Callback = function(v) Settings.Aimbot.AimPart = v end
    })
    
    AimbotTab:CreateSlider({
        Name = "Aim Speed (1=плавно, 10=мгновенно)",
        Range = {1, 10},
        Increment = 1,
        CurrentValue = 10,
        Callback = function(v) 
            Settings.Aimbot.AimSpeed = v
            Settings.Aimbot.Smoothness = v / 20
        end
    })
    
    ESPTab:CreateToggle({
        Name = "ESP Enabled",
        CurrentValue = true,
        Callback = function(v) Settings.ESP.Enabled = v end
    })
    
    ESPTab:CreateToggle({
        Name = "Box ESP",
        CurrentValue = true,
        Callback = function(v) Settings.ESP.Box = v end
    })
    
    ESPTab:CreateToggle({
        Name = "Tracers",
        CurrentValue = true,
        Callback = function(v) Settings.ESP.Tracer = v end
    })
    
    ESPTab:CreateToggle({
        Name = "Skeleton",
        CurrentValue = true,
        Callback = function(v) Settings.ESP.Skeleton = v end
    })
    
    ESPTab:CreateToggle({
        Name = "Health Bar",
        CurrentValue = true,
        Callback = function(v) Settings.ESP.HealthBar = v end
    })
    
    ESPTab:CreateToggle({
        Name = "Distance",
        CurrentValue = true,
        Callback = function(v) Settings.ESP.Distance = v end
    })
    
    ESPTab:CreateColorPicker({
        Name = "Skeleton Color",
        Color = Color3.fromRGB(255, 165, 0),
        Callback = function(v) Settings.ESP.SkeletonColor = v end
    })
    
    TriggerTab:CreateToggle({
        Name = "Auto Trigger Enabled",
        CurrentValue = true,
        Callback = function(v) Settings.Trigger.Enabled = v end
    })
    
    TriggerTab:CreateSlider({
        Name = "Shoot Delay (s)",
        Range = {0.01, 0.3},
        Increment = 0.01,
        CurrentValue = 0.05,
        Callback = function(v) Settings.Trigger.Delay = v end
    })
    
    TriggerTab:CreateToggle({
        Name = "Team Check",
        CurrentValue = true,
        Callback = function(v) Settings.Trigger.TeamCheck = v end
    })
    
    HitboxTab:CreateToggle({
        Name = "Hitbox Enabled",
        CurrentValue = false,
        Callback = function(v) Settings.Hitbox.Enabled = v end
    })
    
    HitboxTab:CreateSlider({
        Name = "Hitbox Size",
        Range = {3, 20},
        Increment = 1,
        CurrentValue = 8,
        Callback = function(v) Settings.Hitbox.Size = v end
    })
    
    HitboxTab:CreateSlider({
        Name = "Hitbox Transparency",
        Range = {0, 1},
        Increment = 0.05,
        CurrentValue = 0.5,
        Callback = function(v) Settings.Hitbox.Transparency = v end
    })
    
    HitboxTab:CreateDropdown({
        Name = "Hitbox Part",
        Options = {"Head", "HumanoidRootPart", "UpperTorso"},
        CurrentOption = "Head",
        Callback = function(v) Settings.Hitbox.Part = v end
    })
    
    VisualTab:CreateToggle({
        Name = "Show FOV Circle",
        CurrentValue = true,
        Callback = function(v) Settings.FOV.Show = v end
    })
    
    VisualTab:CreateSlider({
        Name = "FOV Radius",
        Range = {50, 500},
        Increment = 10,
        CurrentValue = 200,
        Callback = function(v) Settings.FOV.Radius = v end
    })
    
    VisualTab:CreateColorPicker({
        Name = "FOV Color",
        Color = Color3.fromRGB(255, 0, 0),
        Callback = function(v) Settings.FOV.Color = v end
    })
    
    -- Уведомление о загрузке
    Rayfield:Notify({
        Title = "SWILL Ultimate",
        Content = "All features loaded! Key verified.",
        Duration = 5
    })
    
    print("=========================================")
    print("SWILL ULTIMATE v2.0 - LOADED")
    print("Aimbot | ESP | Trigger | Hitbox")
    print("=========================================")
end

-- === ПРОВЕРКА КЛЮЧА ===
local function checkKey()
    local entered = keyBox.Text:gsub("%s+", "")
    
    if entered == correctKey then
        keyGui:Destroy()
        loadMainScript()
    else
        shakeFrame()
        keyBox.Text = ""
        submitBtn.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
        submitBtn.Text = "Invalid Key!"
        task.wait(1.3)
        submitBtn.BackgroundColor3 = Color3.fromRGB(255, 55, 55)
        submitBtn.Text = "Verify Key"
    end
end

-- === ПОДКЛЮЧЕНИЕ К DISCORD ===
local function joinDiscord()
    setclipboard(discordLink)
    
    pcall(function()
        game:GetService("GuiService"):OpenBrowserWindow(discordLink)
    end)

    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "Discord",
        Text = "Link copied! Discord should open automatically.",
        Duration = 5
    })
end

-- === СОБЫТИЯ ДЛЯ KEY GUI ===
submitBtn.MouseButton1Click:Connect(checkKey)
discordBtn.MouseButton1Click:Connect(joinDiscord)

keyBox.FocusLost:Connect(function(enter) 
    if enter then checkKey() end 
end)

UserInputService.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.Escape and keyGui.Parent then
        keyGui:Destroy()
    end
end)
